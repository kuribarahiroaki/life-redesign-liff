-- 診断結果テーブル
create table if not exists diagnoses (
  id uuid primary key default gen_random_uuid(),
  line_user_id text not null,
  answers      jsonb not null,        -- { "q1": 0, "q2": 1, ... }
  result_type  text not null,         -- T1 / T2 / T3 / T4
  tag          text not null,         -- ステップ配信の振り分け用
  created_at   timestamptz default now()
);

-- ⚠ 疎通確認用に anon の insert/select を許可。本番前に必ず締める。
alter table diagnoses enable row level security;

create policy "anon insert (dev only)"
  on diagnoses for insert to anon with check (true);

create policy "anon select (dev only)"
  on diagnoses for select to anon using (true);
